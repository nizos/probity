{
  "name": "Probity",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": ["Anthropic.claude-code"]
    }
  },
  "mounts": [
    "source=probity-claude-config-${devcontainerId},target=/home/node/.claude,type=volume"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/node/.claude"
  },
  "remoteUser": "node",
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code@latest @openai/codex@latest @github/copilot@latest @google/gemini-cli@latest"
}
