{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx @nizos/probity --agent claude-code --debug ${CLAUDE_PROJECT_DIR}/.claude/probity.jsonl"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Edit(**/probity.config.ts)",
      "Write(**/probity.config.ts)",
      "Edit(**/.claude/settings*.json)",
      "Write(**/.claude/settings*.json)"
    ]
  }
}
